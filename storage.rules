rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read if signed in
      allow read: if request.auth != null;
      
      // Allow upload if signed in (Increased limit to 30MB for mobile photos)
      allow write: if request.auth != null && request.resource.size < 30 * 1024 * 1024;
    }
  }
}
