rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read if signed in and belongs to tenant (requires custom metadata or path structure)
      // For now, simple auth check
      allow read: if request.auth != null;
      
      // Only allow upload if signed in
      allow write: if request.auth != null && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }
  }
}
